<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ポケモン種族値クイズ</title>
  <link rel="stylesheet" href="style.css">
</head>

<body>
  <div class="container">

    <!-- 左：種族値 -->
    <div class="stats">
      <div class="stat"><span>H</span><span>100</span></div>
      <div class="stat"><span>A</span><span>120</span></div>
      <div class="stat"><span>B</span><span>90</span></div>
      <div class="stat"><span>C</span><span>60</span></div>
      <div class="stat"><span>D</span><span>90</span></div>
      <div class="stat"><span>S</span><span>95</span></div>
    </div>

    <!-- 右エリア -->
    <div class="right">
      <div class="hints">
        <div class="hint">① タイプ1 <button>表示</button></div>
        <div class="hint">② タイプ2 <button>表示</button></div>
        <div class="hint">③ とくせい1 <button>表示</button></div>
        <div class="hint">④ とくせい2 <button>表示</button></div>
        <div class="hint">⑤ とくせい3 <button>表示</button></div>
        <div class="hint">⑥ 初登場世代 <button>表示</button></div>

        <!-- 回答欄 -->
        <div class="answer">
          <input type="text" placeholder="ポケモン名を入力">
          <button>OK</button>
        </div>
      </div>
    </div>

  </div>
</body>
</html>
